# API Settings
HOST=0.0.0.0
PORT=8000
# rate limit cho /policy/ask, theo IP, đơn vị request/phút
RATE_LIMIT_PER_MINUTE=30


# LLM Provider
# Used by docker-compose and the answer generation pipeline.
# Replace with your actual OpenRouter API key before running.
OPENROUTER_API_KEY=sk-or-v1-...

# Academic Policy Graph RAG Settings
# (Future configurations such as Embedding, Graph DB or Vector DB keys will go here)
# OPENAI_API_KEY=your-api-key-here
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=password
